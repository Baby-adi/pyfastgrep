#!/bin/sh

echo "================================================="
echo "Running pre-push hook for pyfastgrep..."
echo "================================================="

# Use system python for maturin since it needs Rust in PATH
PYTHON_CMD="python"

# Check if we're in a virtual environment with maturin
if [ -n "$VIRTUAL_ENV" ] && command -v maturin >/dev/null 2>&1; then
    echo "Using active virtual environment with maturin..."
    PYTHON_CMD="python"
elif command -v maturin >/dev/null 2>&1; then
    echo "Using system python with maturin..."
else
    echo "❌ Error: maturin not found. Please install maturin or activate a venv with maturin."
    exit 1
fi

# 1. Compile the latest C/Rust extensions
echo "Rebuilding extension with maturin..."
$PYTHON_CMD -m maturin develop
if [ $? -ne 0 ]; then
    echo "Error: Maturin build failed. Ensure Rust is in PATH and maturin is installed. Aborting push."
    exit 1
fi

# 2. Run the automated tests
echo "Running tests..."
$PYTHON_CMD tests/mandatory_tests.py
if [ $? -ne 0 ]; then
    echo "Error: Tests failed. Aborting push."
    exit 1
fi

echo "All checks passed! Proceeding with push."
echo "================================================="
exit 0
